{
  "name": "running-tracker",
  "version": "1.0.0",
  "description": "A small personal app to track how often you have to run to reach your goal",
  "author": "Alexis Roehrling",
  "license": "ISC",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@mantine/core": "9.3.2",
    "@mantine/dates": "9.3.2",
    "@mantine/hooks": "9.3.2",
    "@mantine/notifications": "9.3.2",
    "@tabler/icons-react": "3.44.0",
    "axios": "1.18.0",
    "mantine-datatable": "9.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "24.0.3",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "6.0.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "wrangler": "4.104.0"
  }
}
