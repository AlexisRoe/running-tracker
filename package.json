{
  "name": "running-tracker",
  "version": "0.9.1",
  "description": "A small personal app to track how often you have to run to reach your goal",
  "author": "Alexis Roehrling",
  "license": "ISC",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "5.2.10",
    "@mantine/charts": "9.3.2",
    "@mantine/core": "9.3.2",
    "@mantine/dates": "9.3.2",
    "@mantine/hooks": "9.3.2",
    "@mantine/notifications": "9.3.2",
    "@tabler/icons-react": "3.44.0",
    "axios": "1.18.0",
    "canvas-confetti": "1.9.4",
    "i18next": "26.3.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-router": "7.18.0",
    "recharts": "3.9.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "24.0.3",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "wrangler": "4.104.0"
  }
}
